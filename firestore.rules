rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is approved by admin
    function isApproved() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // Helper: Check if user is a superuser
    function isSuperuser() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superuser';
    }

    // Helper: Verify that the request comes from a legitimate app instance verified by
    // Firebase App Check (reCAPTCHA v3 in production, debug token on localhost).
    // This blocks raw API scripts and bots that bypass the web form entirely.
    function isVerifiedApp() {
      return request.app != null; // request.app is null when no valid App Check token is provided
    }

    // Users collection: 
    // Users can read their own profile. Admin can read all.
    // A user can also read a document where phoneNumber matches their own — required for
    // the deduplication query that prevents duplicate accounts when Auth UID changes.
    match /users/{userId} {
      allow read: if isAuthenticated() && (
                    request.auth.uid == userId ||
                    isSuperuser() ||
                    resource.data.phoneNumber == request.auth.token.phone_number
                  );
      allow write: if isSuperuser(); // Only superuser can change roles/status
      
      // Allow user to create their own profile during registration
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow user to update their own profile (displayName during setup, lastLogin on login)
      // Also allow update if phoneNumber matches — so lastLogin can be updated on phone-matched docs
      allow update: if isAuthenticated() && (
                      (request.auth.uid == userId 
                        && (resource.data.displayName == null 
                            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin'])))
                      ||
                      (resource.data.phoneNumber == request.auth.token.phone_number
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']))
                    );
    }

    // Emergency Requests Collection
    // Public users can submit requests. 
    // Coordinators can manage them (requires status 'approved').
    // Creates now REQUIRE a valid App Check token — blocks bots and raw API flooding.
    // Updates/deletes restricted to approved users (coordinators), EXCEPT for public reopens.
    match /emergency_requests/{requestId} {
      allow read: if true; // Allow public read for duplicate detection
      allow create: if isVerifiedApp(); // Public form submissions allowed with App Check
      allow update: if isApproved() || isVerifiedApp(); // Allow coordinators or public reopens/updates
      allow delete: if isApproved();

      // History entries also require App Check for public submissions
      match /updates/{updateId} {
        allow read: if isAuthenticated();
        allow create: if isVerifiedApp();
        allow update, delete: if isApproved();
      }
    }

    // Donors collection
    // Public can search for donors (needed for duplicate detection and community matching)
    // Public can register as a donor.
    match /donors/{donorId} {
      allow read: if true; // Public read needed for duplicate-detection on registration
      allow create: if isVerifiedApp(); // Public donor registration allowed with App Check
      allow update: if isSuperuser() || isVerifiedApp(); // Only superuser or public registration retry
      allow delete: if isSuperuser();
    }

    // Requests collection (secondary/legacy?)
    match /requests/{requestId} {
      allow read: if true; // Public read for now
      allow create, update: if isApproved() || isVerifiedApp(); 
      allow delete: if isSuperuser();
    }

    // Donation Logs collection
    match /donation_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isApproved();
      allow update, delete: if isSuperuser();
    }
  }
}
